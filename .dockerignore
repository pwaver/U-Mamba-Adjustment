# Keep the build context small. Files listed here are NOT sent to the
# Docker daemon during `docker build`, so they cannot end up in the image
# and cannot bust the layer cache.

# ── Huge, never belongs in the image ─────────────────────────────────────
data/
**/nnUNet_raw/
**/nnUNet_preprocessed/
**/nnUNet_results/

# Local Python env (rebuilt inside the container)
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# Build / packaging outputs (regenerated by the Dockerfile)
umamba/build/
umamba/dist/
umamba/nnunetv2.egg-info/
**/*.egg-info/

# ── Source control / CI / editor state ───────────────────────────────────
.git/
.gitignore
.github/
.idea/
.vscode/
.claude/
.direnv/
.envrc

# ── Model artifacts + logs that shouldn't be baked ───────────────────────
*.pt
*.pth
*.ckpt
*.onnx
*.h5
*.hdf5
*.log
*.sarif
predict_log.txt
report_dynamo_export.sarif
sync_remote_models.sh

# ── Docker artifacts themselves ──────────────────────────────────────────
Dockerfile
.dockerignore

# ── Misc ─────────────────────────────────────────────────────────────────
*.swp
.DS_Store
